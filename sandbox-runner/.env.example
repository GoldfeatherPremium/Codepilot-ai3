# Shared secret — must equal the SANDBOX_RUNNER_TOKEN Supabase secret.
# Generate: openssl rand -hex 32
SANDBOX_RUNNER_TOKEN=

# Per-sandbox resource limits
SANDBOX_CPUS=1
SANDBOX_MEMORY_MB=1024
SANDBOX_DISK_MB=2048
SANDBOX_PIDS_LIMIT=256

# "bridge" allows egress (git clone, npm install); "none" fully isolates
SANDBOX_NETWORK=bridge

# Throughput
MAX_CONCURRENT_JOBS=4
MAX_SESSIONS=20
SESSION_TTL_SECONDS=900
RATE_LIMIT_PER_MINUTE=60

LOG_LEVEL=info
