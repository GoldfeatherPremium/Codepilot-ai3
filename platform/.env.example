# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # server-only, never exposed

# ── Edge function secrets (supabase secrets set ...) ───────────────────────
# 32-byte base64 key:  openssl rand -base64 32
ENCRYPTION_MASTER_KEY=
GITHUB_WEBHOOK_SECRET=
SANDBOX_RUNNER_URL=https://sandbox.yourdomain.com
SANDBOX_RUNNER_TOKEN=
APP_ORIGIN=https://app.codepilot.ai

# ── OAuth (configured in Supabase Auth dashboard) ───────────────────────────
# GitHub OAuth App: scopes  read:user user:email repo
# Google OAuth: standard openid email profile
